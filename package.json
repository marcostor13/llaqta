{
  "name": "llaqta-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "web:start": "bun run --cwd apps/web start",
    "web:build": "bun run --cwd apps/web build",
    "api:start": "bun run --watch apps/api/src/index.ts",
    "api:build": "bun run --cwd apps/api build",
    "build": "bun run web:build && bun run api:build"
  },
  "devDependencies": {
    "netlify-cli": "^19.0.0"
  },
  "dependencies": {
    "@angular/common": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@supabase/supabase-js": "^2.103.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^11.0.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "@zxing/ngx-scanner": "^21.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "rxjs": "^7.8.2",
    "serverless-http": "^4.0.0",
    "tslib": "^2.8.1",
    "uuid": "^13.0.0",
    "zone.js": "^0.16.1"
  }
}
